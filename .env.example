# ==============================================================================
# DATABASE CONFIGURATION
# ==============================================================================
DB_USER=postgres
DB_PASS=your_secure_password_here
DB_NAME=jwt_access_refresh_auth_db
# Use 'localhost' for local launch, or service name (e.g. 'db') if running in Docker (or check env variable in docker compose files)
DB_HOST=localhost
DB_PORT=5432

# ==============================================================================
# AUTHENTICATION & JWT CONFIGURATION
# ==============================================================================
# Generate a trusted key, such as by the command: openssl rand -hex 32
AUTH_JWT_SECRET_KEY=your_super_secret_jwt_key_at_least_32_chars_long
AUTH_JWT_ALGORITHM=HS256

# Token life in seconds (900 sec = 15 min, 604,800 sec = 7 days)
AUTH_ACCESS_TOKEN_TTL=900
AUTH_REFRESH_TOKEN_TTL=604800